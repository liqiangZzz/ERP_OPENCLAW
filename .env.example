# AI 模型（必填）
GLM_API_KEY=
GLM_BASE_URL=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
QWEN_API_KEY=
QWEN_BASE_URL=

# 智谱搜索（不配置时 web_search 工具不可用）
ZHIPU_API_KEY=

# MongoDB
MONGODB_URI=mongodb://root:root@localhost:27017/?authSource=admin
MONGODB_DB_NAME=langchain_db
MONGODB_CHECKPOINT_COLLECTION=checkpoints

# OpenSandbox
SANDBOX_DOMAIN=http://localhost:8081
OPENSANDBOX_API_KEY=
# 开启后服务启动时会创建一个预热沙箱；本地开发建议关闭。
PREWARM_SANDBOX=false
# 默认保留用户远程沙箱，服务重启后可重连。
CLEANUP_SANDBOX_ON_SHUTDOWN=false

# ERP 与 MCP
JAVA_API_BASE_URL=http://localhost:8080/api
MCP_HOST=127.0.0.1
MCP_PORT=8000
MCP_PATH=/mcp
ERP_MCP_URL=http://127.0.0.1:8000/mcp

# 可选。不配置时不加载外部图表 MCP，基础 ERP 功能仍可初始化。
ANALYSIS_MCP_URL=

# Web
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
